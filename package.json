    "type": "git",
    "url": "git+https://github.com/BluesPrince/thiri-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/BluesPrince/thiri-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "music-theory",
    "music-theory-api",
    "music-theory-mcp",
    "chord",
